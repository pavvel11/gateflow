{
  "name": "admin-panel",
  "version": "1.3.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:smoke": "playwright test tests/smoke --project=chromium --workers=2",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:api": "vitest run --config vitest.config.api.ts",
    "test:api:watch": "vitest --config vitest.config.api.ts",
    "test:config": "vitest run --config vitest.config.config.ts",
    "test:a11y": "playwright test --project=accessibility",
    "test:visual": "playwright test --project=visual-mobile --project=visual-tablet --project=visual-laptop --project=visual-wide --project=visual-qhd --project=visual-4k",
    "test:visual:review": "playwright test --project=visual-mobile --project=visual-tablet --project=visual-laptop --project=visual-wide --project=visual-qhd --project=visual-4k && ../../../scripts/dev/visual-review",
    "t": "vitest run && playwright test tests/smoke --project=chromium --workers=2",
    "tt": "vitest run",
    "ttt": "scripts/run-pw.sh --project=chromium; kill $(lsof -ti:3000) 2>/dev/null; RATE_LIMIT_TEST_MODE=true scripts/run-pw.sh --project=rate-limiting --project=rate-limiting-v1",
    "tttt": "cd .. && npx supabase db reset && cd admin-panel && scripts/run-pw.sh --project=chromium; kill $(lsof -ti:3000) 2>/dev/null; RATE_LIMIT_TEST_MODE=true scripts/run-pw.sh --project=rate-limiting --project=rate-limiting-v1"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.4.3",
    "@floating-ui/react": "^0.27.19",
    "@marsidev/react-turnstile": "^1.4.2",
    "@stripe/react-stripe-js": "^5.6.1",
    "@stripe/stripe-js": "^8.9.0",
    "@supabase/auth-ui-react": "^0.4.7",
    "@supabase/auth-ui-shared": "^0.1.8",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.3",
    "bir1": "^4.1.1",
    "date-fns": "^4.1.0",
    "geist": "^1.7.0",
    "javascript-obfuscator": "^5.3.0",
    "lucide-react": "^0.576.0",
    "motion": "^12.34.3",
    "next": "^16.1.6",
    "next-intl": "^4.8.3",
    "react": "^19.2.4",
    "react-confetti": "^6.4.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "stripe": "^20.4.0",
    "swagger-ui-react": "^5.32.0",
    "terser": "^5.46.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/eslintrc": "^3.3.4",
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.11.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/swagger-ui-react": "^5.18.0",
    "@vitest/coverage-v8": "^4.0.18",
    "autocannon": "^8.0.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.3",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
