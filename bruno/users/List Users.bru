meta {
  name: List Users
  type: http
  seq: 1
}

get {
  url: {{BASE_URL}}/api/v1/users
  body: none
  auth: bearer
}

params:query {
  ~search:
  ~cursor:
  ~limit: 20
  ~sort_by: created_at
  ~sort_order: desc
}

auth:bearer {
  token: {{API_KEY}}
}

script:after-response {
  const body = res.getBody();
  const nextCursor = body?.pagination?.next_cursor;
  if (nextCursor) {
    bru.setVar("users_next_cursor", nextCursor);
  } else {
    bru.setVar("users_next_cursor", "");
  }
}

docs {
  # List Users

  Returns cursor-paginated list of users with their product access.

  After the request, `users_next_cursor` is automatically saved
  to a collection variable. Use "List Users - Next Page" to fetch
  the next page.

  ## Query Parameters
  - `search`: search by email
  - `cursor`: pagination cursor from previous response
  - `limit`: items per page, max 100 (default: 20)
  - `sort_by`: created_at | email (default: created_at)
  - `sort_order`: asc | desc (default: desc)

  ## Response
  Returns `data[]` with pagination metadata:
  - `next_cursor`: cursor for next page (null if no more)
  - `has_more`: boolean
  - `total`: total count matching current filters
}
